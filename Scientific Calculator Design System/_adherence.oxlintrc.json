{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/calculator/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:DM Sans|Outfit))/i]",
        "message": "Font not provided by the design system. Available: DM Sans, Outfit."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalcButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|role|onClick|disabled|colSpan|rowSpan|size|style|key|ref|className|style|children)$/]",
        "message": "<CalcButton> doesn't accept that prop. Declared props: label, role, onClick, disabled, colSpan, rowSpan, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalcButton'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:default|operator|scientific|equals|memory|utility|toggle)$/]",
        "message": "<CalcButton> role must be one of 'default' | 'operator' | 'scientific' | 'equals' | 'memory' | 'utility' | 'toggle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalcButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:main|sci|sm|large)$/]",
        "message": "<CalcButton> size must be one of 'main' | 'sci' | 'sm' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Display'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|expression|angleMode|key|ref|className|style|children)$/]",
        "message": "<Display> doesn't accept that prop. Declared props: value, expression, angleMode."
      },
      {
        "selector": "JSXOpeningElement[name.name='Display'] > JSXAttribute[name.name='angleMode'] > Literal[value!=/^(?:DEG|RAD)$/]",
        "message": "<Display> angleMode must be one of 'DEG' | 'RAD'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FunctionChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:expression|color|onRemove|key|ref|className|style|children)$/]",
        "message": "<FunctionChip> doesn't accept that prop. Declared props: expression, color, onRemove."
      },
      {
        "selector": "JSXOpeningElement[name.name='GraphFunction'] > JSXAttribute > JSXIdentifier[name!=/^(?:expression|color|key|ref|className|style|children)$/]",
        "message": "<GraphFunction> doesn't accept that prop. Declared props: expression, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='HistoryItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:expression|result|onClick|key|ref|className|style|children)$/]",
        "message": "<HistoryItem> doesn't accept that prop. Declared props: expression, result, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='HistoryEntry'] > JSXAttribute > JSXIdentifier[name!=/^(?:expression|result|key|ref|className|style|children)$/]",
        "message": "<HistoryEntry> doesn't accept that prop. Declared props: expression, result."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
